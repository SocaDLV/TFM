diff --git a/src/dram_controller/impl/scheduler/PIM_scheduler.cpp b/src/dram_controller/impl/scheduler/PIM_scheduler.cpp
new file mode 100644
index 0000000..bec5950
--- /dev/null
+++ b/src/dram_controller/impl/scheduler/PIM_scheduler.cpp
@@ -0,0 +1,73 @@
+#include <vector>
+
+#include "base/base.h"
+#include "dram_controller/controller.h"
+#include "dram_controller/scheduler.h"
+
+namespace Ramulator {
+
+class PIM_Scheduler : public IScheduler, public Implementation {
+  RAMULATOR_REGISTER_IMPLEMENTATION(IScheduler, PIM_Scheduler, "PIM_Scheduler", "PIM Scheduler.")
+  private:
+    IDRAM* m_dram;
+    bool PIM_mode;
+
+  public:
+    void init() override { 
+      PIM_mode = false;
+    };
+
+    void setup(IFrontEnd* frontend, IMemorySystem* memory_system) override {
+      m_dram = cast_parent<IDRAMController>()->m_dram;
+    };
+
+    ReqBuffer::iterator compare(ReqBuffer::iterator req1, ReqBuffer::iterator req2) override {
+      bool ready1 = m_dram->check_ready(req1->command, req1->addr_vec);
+      bool ready2 = m_dram->check_ready(req2->command, req2->addr_vec);
+
+      if (ready1 ^ ready2) {
+        if (ready1) {
+          return req1;
+        } else {
+          return req2;
+        }
+      }
+
+      // Fallback to FCFS
+      if (req1->arrive <= req2->arrive) {
+        return req1;
+      } else {
+        return req2;
+      } 
+    }
+
+    ReqBuffer::iterator get_best_request(ReqBuffer& buffer) override {
+      if (buffer.size() == 0) {
+        return buffer.end();
+      }
+
+      // pim scheduler
+      // if (buffer.is_pim_buffer) {
+      if (false) {
+        auto req = buffer.begin();
+        req->command =
+            m_dram->get_preq_command(req->final_command, req->addr_vec);
+        return req;
+      } else {
+        // generic scheduller
+        for (auto& req : buffer) {
+          req.command =
+              m_dram->get_preq_command(req.final_command, req.addr_vec);
+        }
+
+        auto candidate = buffer.begin();
+        for (auto next = std::next(buffer.begin(), 1); next != buffer.end();
+             next++) {
+          candidate = compare(candidate, next);
+        }
+        return candidate;
+      }
+    }
+};
+
+}       // namespace Ramulator
